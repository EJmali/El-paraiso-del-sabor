@page "/registro"
@rendermode InteractiveServer
@inject CarritoService CarritoService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Crear Cuenta - El Paraíso del Sabor</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <h2>🍨 Crear Cuenta 🍨</h2>
        <p class="auth-subtitle">Regístrate para guardar tus carritos y personalizar tus sabores.</p>

        <!-- Mensajes de alerta para el usuario -->
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger">⚠️ @mensajeError</div>
        }
        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div class="alert alert-success">✅ @mensajeExito</div>
        }

        <EditForm Model="@modeloRegistro" OnValidSubmit="ManejarRegistro" FormName="FormRegistro">
            <div class="form-group">
                <label>Nombre Completo:</label>
                <input type="text" class="form-control" @bind-value="modeloRegistro.Nombre" placeholder="Ej. Juan Pérez" required />
            </div>

            <div class="form-group">
                <label>Nombre de Usuario (Username):</label>
                <input type="text" class="form-control" @bind-value="modeloRegistro.Username" placeholder="Ej. juan123" required />
            </div>

            <div class="form-group">
                <label>Contraseña:</label>
                <input type="password" class="form-control" @bind-value="modeloRegistro.Password" placeholder="Mínimo 4 caracteres" required />
            </div>

            <button type="submit" class="btn-auth" disabled="@estaCargando">
                @if (estaCargando)
                {
                    <span class="spinner"></span> <span>Registrando...</span>
                }
                else
                {
                    <span>Registrarse 🚀</span>
                }
            </button>
        </EditForm>

        <div class="auth-footer">
            ¿Ya tienes una cuenta? <a href="login">Inicia sesión aquí</a>
        </div>
    </div>
</div>

@code {
    // Clase local rápida para capturar los datos del formulario
    private class RegistroModel
    {
        public string Nombre { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private RegistroModel modeloRegistro = new();
    private string mensajeError = string.Empty;
    private string mensajeExito = string.Empty;
    private bool estaCargando = false;

    private async Task ManejarRegistro()
    {
        // Reseteamos estados y activamos pantalla de carga
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        // Validación básica previa de seguridad
        if (modeloRegistro.Password.Length < 4)
        {
            mensajeError = "La contraseña debe tener al menos 4 caracteres.";
            return;
        }

        estaCargando = true;

        // Llamamos a tu servicio asíncrono pasándole los datos
        bool registrado = AuthService.RegistrarUsuario(
            modeloRegistro.Username, 
            modeloRegistro.Nombre, 
            modeloRegistro.Password
        );

        estaCargando = false;

        if (registrado)
        {
            mensajeExito = "¡Cuenta creada con éxito! Redirigiendo al catálogo...";
            StateHasChanged();
            
            // Pausa de 2 segundos para que el usuario lea el mensaje de éxito antes de moverlo
            await Task.Delay(2000);
            Navigation.NavigateTo("/catalogo");
        }
        else
        {
            mensajeError = "El nombre de usuario ya está registrado por otra persona.";
        }
    }
}

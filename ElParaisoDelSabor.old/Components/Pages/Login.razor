@page "/login"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-container">
    <div class="login-card">
        <h2>🔑 Iniciar Sesión</h2>
        <p>Introduce tus credenciales de acceso</p>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert-danger">⚠️ @mensajeError</div>
        }

        <div class="form-group">
            <label>Usuario:</label>
            <input type="text" class="form-control" @bind="username" placeholder="Ej: erick o admin" />
        </div>

        <div class="form-group">
            <label>Contraseña:</label>
            <input type="password" class="form-control" @bind="password" placeholder="••••••••" />
        </div>

        <button class="btn-login" @onclick="ManejarLogin">Ingresar 🍨</button>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string mensajeError = "";

    private void ManejarLogin()
    {
        if (AuthService.IniciarSesion(username, password))
        {
            Navigation.NavigateTo("/"); // Redirige al inicio si es correcto
        }
        else
        {
            mensajeError = "Usuario o contraseña incorrectos. Revisa e intenta de nuevo.";
        }
    }
}
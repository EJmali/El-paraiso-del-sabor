@page "/catalogo"
@rendermode InteractiveServer
@inject IProductoService ProductoService
@inject CarritoService CarritoService

<PageTitle>Catálogo - El Paraíso del Sabor</PageTitle>

<div class="catalog-container">
    <header class="catalog-header">
        <h1>🍨 Nuestro Menú de Paraíso 🍨</h1>
        <p>Helados artesanales preparados con los mejores ingredientes.</p>
    </header>

    @if (productos == null)
    {
        <div class="loading-box">
            <div class="spinner"></div>
            <p>Cargando los sabores del paraíso...</p>
        </div>
    }
    else if (!productos.Any())
    {
        <p class="empty-catalog">Por el momento no tenemos helados disponibles. ¡Vuelve pronto!</p>
    }
    else
    {
        <section class="catalog-grid">
            @foreach (var helado in productos)
            {
                <article class="ice-cream-card">
                    <div class="card-image">
                        <img src="@(string.IsNullOrEmpty(helado.ImagenUrl) ? "images/default-icecream.png" : helado.ImagenUrl)" 
                             alt="@helado.Nombre" />
                    </div>
                    <div class="card-content">
                        <h3>@helado.Nombre</h3>
                        <p class="description">@helado.Descripcion</p>
                        <div class="card-footer">
                            <span class="price">$@helado.Precio.ToString("F2")</span>
                            <button class="btn-add" @onclick="() => AgregarAlCarrito(helado)">
                                Añadir 🛒
                            </button>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</div>

@code {
    private List<Producto>? productos;

    // Método del ciclo de vida de Blazor: Se ejecuta al cargar la página
    protected override async Task OnInitializedAsync()
    {
        // Llamamos de forma asíncrona a nuestro servicio de base de datos
        productos = await ProductoService.GetProductosAsync();
    }

    private void AgregarAlCarrito(Producto helado)
    {
        CarritoService.AgregarProducto(helado);
        Console.WriteLine($"[Server Log] {helado.Nombre} añadido al carrito global.");
    }
}